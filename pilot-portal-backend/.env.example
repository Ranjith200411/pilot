# Server Configuration
PORT=5000

# Database
MONGO_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/?appName=YourApp

# Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
ACCESS_DURATION_DAYS=30

# AI Services (Choose one or both)
# OpenAI API Key (Recommended for better responses)
OPENAI_API_KEY=sk-your-openai-api-key-here

# HuggingFace API Key (Fallback option)
HF_API_KEY=hf_your_huggingface_api_key_here

# Note: If OPENAI_API_KEY is provided, it will be used.
# Otherwise, the system will fall back to rule-based responses.
# Get your OpenAI API key from: https://platform.openai.com/api-keys
# Get your HuggingFace API key from: https://huggingface.co/settings/tokens
